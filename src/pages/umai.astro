---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import UmaiForm from '@/components/UmaiForm.astro';
import { getCollection } from 'astro:content';

const spots = (await getCollection('posts', ({ data }) =>
  !data.draft && data.categories.includes('うまい店')
)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="うまい店一覧">

  <section>
    <h2 class="section-title">うまい店一覧</h2>
    {spots.length > 0
      ? <PostList posts={spots} />
      : <p class="empty-note">まだ掲載がありません。下のフォームからぜひ教えてください。</p>
    }
  </section>

  <div class="divider"><span class="ornament">◆</span></div>

  <UmaiForm />

</BaseLayout>

<style>
  .section-title {
    font-family: var(--decol);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .empty-note { color: var(--muted); font-size: 0.92rem; }
  .divider { display: flex; align-items: center; gap: 0.6rem; margin: 2.5rem 0; }
  .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--rule); }
  .ornament { font-size: 0.55rem; color: var(--accent); opacity: 0.45; }
</style>
