---
import BaseLayout from '@/layouts/BaseLayout.astro';

const forms = [
  {
    title:       'うまい店フォーム',
    description: 'おすすめの飲食店・居酒屋・カフェなどを投稿してください。内容を確認後に「うまい店一覧」へ掲載します。',
    href:        '/forms/umai/',
    emoji:       '🍜',
  },
  // 新しいフォームはここに追加
];
---

<BaseLayout title="Forms" description="各種投稿フォームの一覧です。">
  <div class="forms-header">
    <h2 class="forms-title">Forms</h2>
    <p class="forms-desc">投稿・お問い合わせはこちらから。</p>
  </div>

  <ul class="forms-list">
    {forms.map(f => (
      <li class="form-card">
        <a href={f.href} class="form-card-link">
          <span class="form-card-emoji">{f.emoji}</span>
          <div class="form-card-body">
            <p class="form-card-title">{f.title}</p>
            <p class="form-card-desc">{f.description}</p>
          </div>
          <span class="form-card-arrow">→</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .forms-header { margin-bottom: 2rem; }
  .forms-title {
    font-family: var(--decol);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 0.3rem;
  }
  .forms-desc { margin: 0; font-size: 0.9rem; color: var(--muted); }

  .forms-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.8rem; }

  .form-card {
    background: rgba(255, 252, 244, 0.65);
    border: 1px solid var(--rule);
    border-radius: 5px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .form-card:hover {
    box-shadow: 0 3px 12px rgba(49,100,96,0.1);
    transform: translateY(-1px);
  }
  .form-card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    color: inherit;
    text-decoration: none;
  }
  .form-card-emoji { font-size: 1.8rem; flex-shrink: 0; }
  .form-card-body { flex: 1; }
  .form-card-title {
    margin: 0 0 0.25rem;
    font-family: var(--decol);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
  }
  .form-card-desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .form-card-arrow {
    font-size: 1rem;
    color: var(--accent);
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .form-card:hover .form-card-arrow {
    opacity: 1;
    transform: translateX(3px);
  }
</style>
